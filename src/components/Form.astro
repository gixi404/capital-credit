---
import { WHATSAPP_URL } from "../utils/const";
import WhatsAppIcon from "../assets/svg/whatsapp.svg";
import ArrowBackIcon from "../assets/svg/arrow-back.svg";
---

<section id="formulario" class="py-[6rem] sm:py-[8rem] bg-gray-800">
  <div
    class="container mx-auto max-w-[1000px] flex justify-center items-center flex-col px-4"
  >
    <div class="mb-10 w-full flex flex-col justify-center items-center gap-y-8">
      <h2 class="text-center w-full text-5xl font-bold text-gray-100">
        Formulario
      </h2>
      <div
        class="flex flex-col text-lg px-4 sm:px-0 items-center justify-center gap-y-2 text-gray-300/95 w-full"
      >
        <p class="text-center flex flex-col sm:flex-row">
          ¿Es tu primera vez con nosotros?
          <span>&nbsp;Completá el formulario para que analicemos tu perfil</span
          >
        </p>
        <p
          class="flex flex-col sm:flex-row text-center sm:text-start justify-start items-center"
        >
          ¿Ya sos cliente y querés renovar?

          <span class="flex gap-x-2">
            &nbsp;Hacé clic acá:
            <a
              rel="noreferrer"
              target="_blank"
              href={`${WHATSAPP_URL}?text=Hola CAPITAL CREDIT, solicito una renovación...`}
              class="opacity-90 hover:brightness-125 transition-opacity"
            >
              <WhatsAppIcon class="size-6" />
            </a>
          </span>
        </p>
      </div>
    </div>
    <div
      class="w-full max-w-lg bg-[#101828] border-2 border-gray-600/40 rounded-lg shadow-md p-6"
    >
      <form
        id="form-main"
        class="flex flex-col"
        method="post"
        action="/api/submit"
        enctype="multipart/form-data"
      >
        <label for="dni" class="flex flex-col gap-y-1 text-gray-100">
          DNI
          <input
            required
            type="text"
            id="dni"
            name="dni"
            placeholder="12.345.678"
            class="bg-[#202733] border border-[#2d3646] cursor-pointer outline-0 text-white rounded-md p-2.5 mb-4 focus:bg-gray-700 focus:outline-none focus:ring-1 focus:ring-[#f3efe7] transition ease-in-out duration-150 w-full"
          />
        </label>
        <label for="email" class="flex flex-col gap-y-1 text-gray-100">
          Email
          <input
            id="email"
            type="email"
            name="email"
            inputmode="email"
            minlength={5}
            maxlength={254}
            placeholder="ejemplo@gmail.com"
            autocapitalize="off"
            spellcheck={false}
            autocorrect="off"
            autocomplete="on"
            required
            class="bg-[#202733] border border-[#2d3646] cursor-pointer outline-0 text-white rounded-md p-2.5 mb-4 focus:bg-gray-700 focus:outline-none focus:ring-1 focus:ring-[#f3efe7] transition ease-in-out duration-150 w-full"
          />
        </label>
        <label for="phone" class="flex flex-col gap-y-1 text-gray-100">
          Celular
          <input
            required
            type="number"
            id="phone"
            name="phone"
            placeholder="+5491176294118"
            class="bg-[#202733] border border-[#2d3646] cursor-pointer outline-0 text-white rounded-md p-2.5 mb-4 focus:bg-gray-700 focus:outline-none focus:ring-1 focus:ring-[#f3efe7] transition ease-in-out duration-150 w-full"
            type="text"
          />
        </label>
        <label
          for="condition"
          class="mb-1 relative text-gray-200 cursor-pointer"
        >
          Condición laboral
          <ArrowBackIcon />
        </label>

        <select
          class="bg-[#202733] border border-[#2d3646] cursor-pointer outline-0 text-white rounded-md p-2.5 mb-4 focus:bg-gray-700 focus:outline-none focus:ring-1 focus:ring-[#f3efe7] transition ease-in-out duration-150 w-full"
          required
          id="condition"
          name="condition"
        >
          <option disabled selected value="default"
            >Seleccioná una opción</option
          >
          <option value="Trabajo informal (sin recibo)"
            >Trabajo informal (sin recibo)</option
          >
          <option value="Trabajo en relación de dependencia (con recibo)"
            >Trabajo en relación de dependencia (con recibo)
          </option>
          <option value="Jubilado/a">Jubilado/a</option>
          <option value="Monotributista">Monotributista</option>
          <option value="Emprendedor/a o trabajador independiente"
            >Emprendedor/a o trabajador independiente</option
          >
        </select>
        <button
          class="bg-gradient-to-b border-b-3 border-green-300/10 from-green-500 to-green-600 text-white font-bold py-2 rounded-md mt-4 hover:brightness-110 transition-colors cursor-pointer text-xl sm:text-2xl tracking-wide"
          type="submit"
          id="form-btn"
        >
          Enviar
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  window?.document?.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("form-main") as HTMLFormElement;
    const btn = document.getElementById("form-btn") as HTMLButtonElement;

    form.addEventListener("submit", (e: Event) => {
      e.preventDefault();

      const dni: string = form.dni.value.trim(),
        email: string = form.email.value.trim(),
        phone: string = form.phone.value.trim(),
        condition: string = form.condition.value,
        errors: string[] = [];

      if (false) {
        errors.push("DNI inválido (7 u 8 dígitos)");
      }

      if (false) {
        errors.push("Email inválido");
      }

      if (false) {
        errors.push("Celular inválido (entre 10 y 15 dígitos)");
      }

      if (condition == "default") {
        errors.push("Seleccioná una condición laboral de la lista");
      }

      if (errors.length > 0) {
        window?.alert(errors.join("\n"));
        btn.disabled = false;
        btn.innerText = "Enviar";
        btn.style.pointerEvents = "auto";
        btn.style.opacity = "1";
        return;
      }

      btn.disabled = true;
      btn.innerText = "Enviando...";
      btn.style.pointerEvents = "none";
      btn.style.opacity = "0.9";
      form.submit();
    });
  });
</script>
